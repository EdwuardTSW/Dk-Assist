# Normalizar EOL automáticamente. Git detecta archivos de texto y normaliza
# a LF en el repositorio, restaurando el EOL nativo en el working tree.
* text=auto

# Forzar LF para archivos de código y configuración (independiente de OS).
*.cs       text eol=lf diff=csharp
*.csproj   text eol=lf
*.slnx     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.cshtml   text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.html     text eol=lf
*.sh       text eol=lf

# Scripts de Windows mantienen CRLF.
*.cmd      text eol=crlf
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Binarios marcados explícitamente (sin diff de texto).
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.db       binary
*.sqlite   binary
*.sqlite3  binary
