@model DkAssist.Presentation.Models.CitaViewModel
@{ ViewData["Title"] = "Eliminar cita"; }

<h1 class="text-danger">¿Eliminar esta cita?</h1>
<p>Esta acción no se puede deshacer.</p>

<div class="card col-md-6 mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Cliente</dt><dd class="col-sm-8 text-break">@Model.ClienteNombre</dd>
            <dt class="col-sm-4">Fecha y hora</dt><dd class="col-sm-8">@Model.FechaHora.ToLocalTime().ToString("g")</dd>
            <dt class="col-sm-4">Tipo</dt><dd class="col-sm-8 text-break">@Model.Tipo</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>
