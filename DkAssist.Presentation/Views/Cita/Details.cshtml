@model DkAssist.Presentation.Models.CitaViewModel
@{ ViewData["Title"] = "Detalle de la cita"; }

<h1>Cita @Model.Id</h1>

<div class="card col-md-6">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Cliente</dt><dd class="col-sm-8 text-break">@Model.ClienteNombre</dd>
            <dt class="col-sm-4">Fecha y hora</dt><dd class="col-sm-8">@Model.FechaHora.ToLocalTime().ToString("g")</dd>
            <dt class="col-sm-4">Tipo</dt><dd class="col-sm-8 text-break">@Model.Tipo</dd>
            <dt class="col-sm-4">Estado</dt><dd class="col-sm-8">@Model.Estado</dd>
            <dt class="col-sm-4">Notas</dt><dd class="col-sm-8 text-break">@Model.Notas</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-link">Volver</a>
</div>
