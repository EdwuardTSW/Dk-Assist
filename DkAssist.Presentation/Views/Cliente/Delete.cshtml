@model DkAssist.Presentation.Models.ClienteViewModel
@{ ViewData["Title"] = "Eliminar cliente"; }

<h1 class="text-danger">¿Eliminar este cliente?</h1>
<p>Esta acción no se puede deshacer.</p>

<div class="card col-md-6 mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt><dd class="col-sm-9">@Model.Nombre</dd>
            <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Teléfono</dt><dd class="col-sm-9">@Model.Telefono</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>
