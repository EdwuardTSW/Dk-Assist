@model DkAssist.Presentation.Models.ClienteViewModel
@{ ViewData["Title"] = "Editar cliente"; }

<h1>Editar cliente</h1>

<form asp-action="Edit" method="post" class="col-md-6" novalidate>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="FechaRegistro" />

    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" aria-describedby="Nombre-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Nombre)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="name" />
        <span id="Nombre-error" asp-validation-for="Nombre" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefono" class="form-label"></label>
        <input asp-for="Telefono" type="tel" class="form-control" aria-describedby="Telefono-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Telefono)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="tel" inputmode="tel" />
        <span id="Telefono-error" asp-validation-for="Telefono" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" type="email" class="form-control" aria-describedby="Email-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Email)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="email" inputmode="email" spellcheck="false" />
        <span id="Email-error" asp-validation-for="Email" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Direccion" class="form-label"></label>
        <input asp-for="Direccion" class="form-control" aria-describedby="Direccion-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Direccion)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="street-address" />
        <span id="Direccion-error" asp-validation-for="Direccion" class="text-danger" role="alert"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
