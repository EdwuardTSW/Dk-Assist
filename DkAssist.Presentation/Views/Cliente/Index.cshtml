@model IEnumerable<DkAssist.Presentation.Models.ClienteViewModel>
@{ ViewData["Title"] = "Clientes"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Clientes</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo cliente</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay clientes registrados. Crea el primero con el botón "Nuevo cliente".</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de clientes registrados</caption>
            <thead>
                <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col">Teléfono</th>
                    <th scope="col">Email</th>
                    <th scope="col">Registro</th>
                    <th scope="col"><span class="visually-hidden">Acciones</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td>@cliente.Nombre</td>
                        <td>@cliente.Telefono</td>
                        <td>@cliente.Email</td>
                        <td>@cliente.FechaRegistro.ToLocalTime().ToString("g")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@cliente.Id" aria-label="Ver detalles de @cliente.Nombre">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@cliente.Id" aria-label="Editar a @cliente.Nombre">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@cliente.Id" aria-label="Eliminar a @cliente.Nombre">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
