@model DkAssist.Presentation.Models.CotizacionViewModel
@{ ViewData["Title"] = "Detalle de la cotización"; }

<h1>Cotización @Model.Id</h1>

<div class="card col-lg-8 mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Cliente</dt><dd class="col-sm-9 text-break">@Model.ClienteNombre</dd>
            <dt class="col-sm-3">Fecha</dt><dd class="col-sm-9">@Model.Fecha.ToLocalTime().ToString("g")</dd>
            <dt class="col-sm-3">Vigencia</dt><dd class="col-sm-9">@Model.Vigencia.ToLocalTime().ToString("d")</dd>
            <dt class="col-sm-3">Estado</dt><dd class="col-sm-9">@Model.Estado</dd>
            <dt class="col-sm-3">Total</dt><dd class="col-sm-9">@Model.Total.ToString("C")</dd>
            <dt class="col-sm-3">Notas</dt><dd class="col-sm-9 text-break">@Model.Notas</dd>
        </dl>
    </div>
</div>

<div class="table-responsive col-lg-8">
    <table class="table table-sm">
        <caption class="visually-hidden">Productos de la cotización</caption>
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductoNombre</td>
                    <td>@item.Cantidad</td>
                    <td>@item.PrecioUnitario.ToString("C")</td>
                    <td>@item.Subtotal.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-link">Volver</a>
</div>
