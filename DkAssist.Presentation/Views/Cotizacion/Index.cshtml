@model IEnumerable<DkAssist.Presentation.Models.CotizacionViewModel>
@{ ViewData["Title"] = "Cotizaciones"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Cotizaciones</h1>
    <a class="btn btn-primary" asp-action="Create">Nueva cotización</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay cotizaciones registradas. Crea la primera con el botón Nueva cotización.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de cotizaciones registradas</caption>
            <thead><tr><th>Cliente</th><th>Fecha</th><th>Vigencia</th><th>Estado</th><th>Total</th><th><span class="visually-hidden">Acciones</span></th></tr></thead>
            <tbody>
                @foreach (var cotizacion in Model)
                {
                    <tr>
                        <td class="text-break">@cotizacion.ClienteNombre</td>
                        <td>@cotizacion.Fecha.ToLocalTime().ToString("g")</td>
                        <td>@cotizacion.Vigencia.ToLocalTime().ToString("d")</td>
                        <td>@cotizacion.Estado</td>
                        <td>@cotizacion.Total.ToString("C")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@cotizacion.Id" aria-label="Ver detalles de la cotización @cotizacion.Id">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@cotizacion.Id" aria-label="Editar cotización @cotizacion.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@cotizacion.Id" aria-label="Eliminar cotización @cotizacion.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
