@model IEnumerable<DkAssist.Presentation.Models.MovimientoStockViewModel>
@{ ViewData["Title"] = "Inventario"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inventario</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo movimiento</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay movimientos de stock registrados.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de movimientos de inventario</caption>
            <thead><tr><th scope="col">Producto</th><th scope="col">Tipo</th><th scope="col">Cantidad</th><th scope="col">Fecha</th><th scope="col">Motivo</th><th scope="col"><span class="visually-hidden">Acciones</span></th></tr></thead>
            <tbody>
                @foreach (var movimiento in Model)
                {
                    <tr>
                        <td class="text-break">@movimiento.ProductoNombre</td>
                        <td>@movimiento.Tipo</td>
                        <td>@movimiento.Cantidad</td>
                        <td>@movimiento.Fecha.ToLocalTime().ToString("g")</td>
                        <td class="text-break">@movimiento.Motivo</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@movimiento.Id" aria-label="Ver detalles del movimiento @movimiento.Id">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@movimiento.Id" aria-label="Editar movimiento @movimiento.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@movimiento.Id" aria-label="Eliminar movimiento @movimiento.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
