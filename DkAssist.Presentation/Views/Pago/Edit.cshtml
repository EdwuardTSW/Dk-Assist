@model DkAssist.Presentation.Models.PagoViewModel
@{ ViewData["Title"] = "Editar pago"; }

<h1>Editar pago</h1>

<form asp-action="Edit" method="post" class="col-md-6" novalidate>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Fecha" />
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="PedidoId" class="form-label"></label>
        <select asp-for="PedidoId" asp-items="Model.Pedidos" class="form-select">
            <option value="0">Selecciona un pedido</option>
        </select>
        <span asp-validation-for="PedidoId" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Monto" class="form-label"></label>
        <input asp-for="Monto" class="form-control" inputmode="decimal" />
        <span asp-validation-for="Monto" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Metodo" class="form-label"></label>
        <input asp-for="Metodo" class="form-control" />
        <span asp-validation-for="Metodo" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Referencia" class="form-label"></label>
        <input asp-for="Referencia" class="form-control" translate="no" />
        <span asp-validation-for="Referencia" class="text-danger" role="alert"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
