@model IEnumerable<DkAssist.Presentation.Models.PagoViewModel>
@{ ViewData["Title"] = "Pagos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pagos</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo pago</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay pagos registrados. Crea el primero con el botón Nuevo pago.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de pagos registrados</caption>
            <thead><tr><th>Pedido</th><th>Monto</th><th>Método</th><th>Fecha</th><th>Referencia</th><th><span class="visually-hidden">Acciones</span></th></tr></thead>
            <tbody>
                @foreach (var pago in Model)
                {
                    <tr>
                        <td class="text-break">@pago.PedidoDescripcion</td>
                        <td>@pago.Monto.ToString("C")</td>
                        <td>@pago.Metodo</td>
                        <td>@pago.Fecha.ToLocalTime().ToString("g")</td>
                        <td class="text-break" translate="no">@pago.Referencia</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@pago.Id" aria-label="Ver detalles del pago @pago.Id">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@pago.Id" aria-label="Editar pago @pago.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@pago.Id" aria-label="Eliminar pago @pago.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
