@model DkAssist.Presentation.Models.PedidoViewModel
@{ ViewData["Title"] = "Nuevo pedido"; }

<h1>Nuevo pedido</h1>

<form asp-action="Create" method="post" class="col-lg-9" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="ClienteId" class="form-label"></label>
        <div class="input-group">
            <select asp-for="ClienteId" asp-items="Model.Clientes" class="form-select"
                    aria-describedby="ClienteId-error"
                    aria-invalid="@(ViewData.ModelState[nameof(Model.ClienteId)]?.Errors.Count > 0 ? "true" : "false")">
                <option value="0">Selecciona un cliente</option>
            </select>
            <a asp-controller="Cliente" asp-action="Create" target="_blank"
               class="btn btn-outline-secondary" title="Crear nuevo cliente (abre en nueva pestaña)">+ Nuevo</a>
        </div>
        <span id="ClienteId-error" asp-validation-for="ClienteId" class="text-danger" role="alert"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Estado</label>
            <input type="hidden" asp-for="Estado" id="estadoHidden" />
            <select id="estadoSelect" class="form-select">
                <option value="Pendiente">Pendiente</option>
                <option value="En proceso">En proceso</option>
                <option value="Listo para envío">Listo para envío</option>
                <option value="Enviado">Enviado</option>
                <option value="Entregado">Entregado</option>
                <option value="Cancelado">Cancelado</option>
                <option value="__otro__">Personalizado…</option>
            </select>
            <input type="text" id="estadoPersonalizado" class="form-control mt-2"
                   placeholder="Escribe el estado" style="display:none" maxlength="50" />
            <span asp-validation-for="Estado" class="text-danger" role="alert"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha de entrega</label>
            <div class="form-check mb-1">
                <input type="checkbox" class="form-check-input" id="tieneFechaEntrega">
                <label class="form-check-label" for="tieneFechaEntrega">Tiene fecha de entrega</label>
            </div>
            <div id="fechaEntregaContainer" style="display:none">
                <input asp-for="FechaEntrega" type="date" class="form-control" id="fechaEntregaInput" />
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Notas" class="form-label"></label>
        <textarea asp-for="Notas" class="form-control" rows="3"></textarea>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">Productos</h2>
        <a asp-controller="Producto" asp-action="Create" target="_blank"
           class="btn btn-sm btn-outline-secondary" title="Crear nuevo producto (abre en nueva pestaña)">+ Nuevo producto</a>
    </div>

    <div class="items-container">
        @for (var i = 0; i < Model.Items.Count; i++)
        {
            <div class="row g-2 align-items-end mb-2 item-row">
                <div class="col-md-5">
                    <label asp-for="Items[i].ProductoId" class="form-label"></label>
                    <select asp-for="Items[i].ProductoId" asp-items="Model.Productos" class="form-select producto-select">
                        <option value="0">Selecciona un producto</option>
                    </select>
                    <span asp-validation-for="Items[i].ProductoId" class="text-danger" role="alert"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Items[i].Cantidad" class="form-label"></label>
                    <input asp-for="Items[i].Cantidad" type="number" min="1" class="form-control" inputmode="numeric" />
                    <span asp-validation-for="Items[i].Cantidad" class="text-danger" role="alert"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Items[i].PrecioUnitario" class="form-label"></label>
                    <input asp-for="Items[i].PrecioUnitario" class="form-control precio-unitario" inputmode="decimal" />
                    <span asp-validation-for="Items[i].PrecioUnitario" class="text-danger" role="alert"></span>
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger w-100 remove-item" aria-label="Quitar">&times;</button>
                </div>
            </div>
        }
    </div>
    <button type="button" class="btn btn-outline-secondary btn-sm mb-3 add-item">+ Agregar producto</button>

    <div>
        <button type="submit" class="btn btn-primary">Guardar pedido</button>
        <a asp-action="Index" class="btn btn-link">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var precios = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductoPrecios));

        document.querySelector('.items-container').addEventListener('change', function (e) {
            if (!e.target.classList.contains('producto-select')) return;
            var id = parseInt(e.target.value);
            var row = e.target.closest('.item-row');
            var precioInput = row.querySelector('.precio-unitario');
            if (precioInput && id > 0 && precios[id] !== undefined) {
                precioInput.value = precios[id];
            }
        });

        var estadoSelect = document.getElementById('estadoSelect');
        var estadoHidden = document.getElementById('estadoHidden');
        var estadoPersonalizado = document.getElementById('estadoPersonalizado');
        var predefinidos = ['Pendiente', 'En proceso', 'Listo para envío', 'Enviado', 'Entregado', 'Cancelado'];

        function syncEstado() {
            var val = estadoHidden.value || 'Pendiente';
            if (predefinidos.includes(val)) {
                estadoSelect.value = val;
                estadoPersonalizado.style.display = 'none';
            } else {
                estadoSelect.value = '__otro__';
                estadoPersonalizado.value = val;
                estadoPersonalizado.style.display = '';
            }
        }

        estadoSelect.addEventListener('change', function () {
            if (this.value === '__otro__') {
                estadoPersonalizado.style.display = '';
                estadoPersonalizado.focus();
                estadoHidden.value = estadoPersonalizado.value;
            } else {
                estadoPersonalizado.style.display = 'none';
                estadoHidden.value = this.value;
            }
        });

        estadoPersonalizado.addEventListener('input', function () {
            estadoHidden.value = this.value;
        });

        syncEstado();

        var checkFecha = document.getElementById('tieneFechaEntrega');
        var contenedorFecha = document.getElementById('fechaEntregaContainer');
        var inputFecha = document.getElementById('fechaEntregaInput');

        checkFecha.addEventListener('change', function () {
            contenedorFecha.style.display = this.checked ? '' : 'none';
            if (!this.checked) inputFecha.value = '';
        });
    })();
    </script>
}
