@model IEnumerable<DkAssist.Presentation.Models.PedidoViewModel>
@{ ViewData["Title"] = "Pedidos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pedidos</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo pedido</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger" role="alert" aria-live="assertive">@err</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay pedidos registrados. Crea el primero con el botón Nuevo pedido.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de pedidos registrados</caption>
            <thead>
                <tr>
                    <th scope="col">Cliente</th>
                    <th scope="col">Fecha</th>
                    <th scope="col">Estado</th>
                    <th scope="col">Total</th>
                    <th scope="col"><span class="visually-hidden">Acciones</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in Model)
                {
                    <tr>
                        <td class="text-break">@pedido.ClienteNombre</td>
                        <td>@pedido.Fecha.ToLocalTime().ToString("g")</td>
                        <td>@pedido.Estado</td>
                        <td>@pedido.Total.ToString("C")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@pedido.Id" aria-label="Ver detalles del pedido @pedido.Id">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@pedido.Id" aria-label="Editar pedido @pedido.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@pedido.Id" aria-label="Eliminar pedido @pedido.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
