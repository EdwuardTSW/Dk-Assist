@model DkAssist.Presentation.Models.ProductoViewModel
@{ ViewData["Title"] = "Detalle del producto"; }

<h1>@Model.Nombre</h1>

<div class="card col-md-6">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">SKU</dt><dd class="col-sm-9 text-break" translate="no">@Model.SKU</dd>
            <dt class="col-sm-3">Descripción</dt><dd class="col-sm-9 text-break">@Model.Descripcion</dd>
            <dt class="col-sm-3">Precio</dt><dd class="col-sm-9">@Model.Precio.ToString("C")</dd>
            <dt class="col-sm-3">Stock</dt><dd class="col-sm-9">@Model.Stock</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-link">Volver</a>
</div>
