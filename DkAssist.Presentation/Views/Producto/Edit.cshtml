@model DkAssist.Presentation.Models.ProductoViewModel
@{ ViewData["Title"] = "Editar producto"; }

<h1>Editar producto</h1>

<form asp-action="Edit" method="post" class="col-md-6" novalidate>
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" aria-describedby="Nombre-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Nombre)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="off" />
        <span id="Nombre-error" asp-validation-for="Nombre" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" aria-describedby="Descripcion-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Descripcion)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="off" rows="3"></textarea>
        <span id="Descripcion-error" asp-validation-for="Descripcion" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Precio" class="form-label"></label>
        <input asp-for="Precio" class="form-control" aria-describedby="Precio-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Precio)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="off" inputmode="decimal" />
        <span id="Precio-error" asp-validation-for="Precio" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Stock" class="form-label"></label>
        <input asp-for="Stock" class="form-control" aria-describedby="Stock-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Stock)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="off" inputmode="numeric" />
        <span id="Stock-error" asp-validation-for="Stock" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SKU" class="form-label"></label>
        <input asp-for="SKU" class="form-control" aria-describedby="SKU-error" aria-invalid="@(ViewData.ModelState[nameof(Model.SKU)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="off" />
        <span id="SKU-error" asp-validation-for="SKU" class="text-danger" role="alert"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
