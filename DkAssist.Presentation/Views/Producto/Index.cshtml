@model IEnumerable<DkAssist.Presentation.Models.ProductoViewModel>
@using DkAssist.Domain.Models
@{ ViewData["Title"] = "Productos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Productos</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo producto</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay productos registrados. Crea el primero con el botón Nuevo producto.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de productos registrados</caption>
            <thead>
                <tr>
                    <th scope="col" style="width:48px"></th>
                    <th scope="col">Nombre</th>
                    <th scope="col">Categoría</th>
                    <th scope="col">SKU</th>
                    <th scope="col">Precio</th>
                    <th scope="col">Stock</th>
                    <th scope="col"><span class="visually-hidden">Acciones</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producto in Model)
                {
                    <tr>
                        <td>
                            <div class="producto-icono-sm">
                                @if (producto.ImagenPath is not null)
                                {
                                    <img src="@producto.ImagenPath" alt="@producto.Nombre" class="producto-imagen-sm" />
                                }
                                else
                                {
                                    <partial name="_ProductoIcono" model="producto.Categoria" />
                                }
                            </div>
                        </td>
                        <td class="text-break">@producto.Nombre</td>
                        <td>@producto.Categoria</td>
                        <td class="text-break" translate="no">@producto.SKU</td>
                        <td>@producto.Precio.ToString("C")</td>
                        <td>@(producto.Stock == 0 ? "Indefinido" : producto.Stock.ToString())</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@producto.Id" aria-label="Ver detalles de @producto.Nombre">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@producto.Id" aria-label="Editar @producto.Nombre">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@producto.Id" aria-label="Eliminar @producto.Nombre">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
