@using DkAssist.Api.ExternalCatalogs
@model ProveedorCatalogoResult
@{
    ViewData["Title"] = "Catálogos externos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted text-uppercase fw-bold small mb-1">Proveedores externos</p>
        <h1 class="mb-0">Catálogos externos</h1>
        <p class="text-muted mb-0">Productos desde @Model.ProviderName</p>
    </div>
    <a asp-action="CatalogosExternos" class="btn btn-outline-secondary">← Volver a catálogos externos</a>
</div>

@if (ViewBag.Error is string error)
{
    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        @error
    </div>
}

@if (!Model.Productos.Any())
{
    <p class="text-muted">El proveedor no tiene productos disponibles en este momento.</p>
}
else
{
    <p class="text-muted mb-3">@Model.Productos.Count productos encontrados en @Model.ProviderName</p>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var producto in Model.Productos)
        {
            <div class="col">
                <article class="card h-100 shadow-sm">
                    <div class="d-flex align-items-center justify-content-center p-3 catalog-product-image">
                        <img src="@producto.Image"
                             alt="@producto.Title"
                             class="img-fluid"
                             style="max-height:170px; object-fit:contain;" />
                    </div>
                    <div class="card-body d-flex flex-column">
                        <span class="badge text-bg-secondary mb-2" style="width:fit-content">@producto.Category</span>
                        <span class="text-muted small mb-2">@producto.Source</span>
                        <h2 class="card-title h6 fw-semibold">@producto.Title</h2>
                        <p class="card-text text-muted small flex-grow-1"
                           style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                            @producto.Description
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fs-5 fw-bold text-success">@producto.Price.ToString("C")</span>
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalDetalle"
                                    data-id="@producto.Id"
                                    data-title="@producto.Title"
                                    data-price="@producto.Price.ToString("C")"
                                    data-category="@producto.Category"
                                    data-description="@producto.Description"
                                    data-image="@producto.Image">
                                Ver detalles
                            </button>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>

    <!-- Modal de detalles -->
    <div class="modal fade" id="modalDetalle" tabindex="-1" aria-labelledby="modalDetalleLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5" id="modalDetalleLabel"></h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-4">
                        <div class="col-md-4 d-flex align-items-center justify-content-center catalog-product-image catalog-product-image-modal">
                            <img id="modalImagen" src="" alt="" class="img-fluid" style="max-height:200px; object-fit:contain;" />
                        </div>
                        <div class="col-md-8">
                            <span id="modalCategoria" class="badge text-bg-secondary mb-2"></span>
                            <p id="modalDescripcion" class="text-muted"></p>
                            <hr />
                            <p class="mb-0">
                                <span class="text-muted">Precio unitario:</span>
                                <span id="modalPrecio" class="fs-4 fw-bold text-success ms-2"></span>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
    document.getElementById('modalDetalle').addEventListener('show.bs.modal', function (e) {
        var btn = e.relatedTarget;
        document.getElementById('modalDetalleLabel').textContent = btn.dataset.title;
        document.getElementById('modalCategoria').textContent    = btn.dataset.category;
        document.getElementById('modalDescripcion').textContent  = btn.dataset.description;
        document.getElementById('modalPrecio').textContent       = btn.dataset.price;
        var img = document.getElementById('modalImagen');
        img.src = btn.dataset.image;
        img.alt = btn.dataset.title;
    });
    </script>
}
