@model DkAssist.Presentation.Models.ProveedorViewModel
@{ ViewData["Title"] = "Nuevo proveedor"; }

<h1>Nuevo proveedor</h1>

<form asp-action="Create" method="post" class="col-md-6" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" aria-describedby="Nombre-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Nombre)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="organization" />
        <span id="Nombre-error" asp-validation-for="Nombre" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Contacto" class="form-label"></label>
        <input asp-for="Contacto" class="form-control" aria-describedby="Contacto-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Contacto)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="name" />
        <span id="Contacto-error" asp-validation-for="Contacto" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefono" class="form-label"></label>
        <input asp-for="Telefono" type="tel" class="form-control" aria-describedby="Telefono-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Telefono)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="tel" inputmode="tel" />
        <span id="Telefono-error" asp-validation-for="Telefono" class="text-danger" role="alert"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" type="email" class="form-control" aria-describedby="Email-error" aria-invalid="@(ViewData.ModelState[nameof(Model.Email)]?.Errors.Count > 0 ? "true" : "false")" autocomplete="email" inputmode="email" spellcheck="false" />
        <span id="Email-error" asp-validation-for="Email" class="text-danger" role="alert"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
