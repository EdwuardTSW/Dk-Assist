@model DkAssist.Presentation.Models.ProveedorViewModel
@{ ViewData["Title"] = "Eliminar proveedor"; }

<h1 class="text-danger">¿Eliminar este proveedor?</h1>
<p>Esta acción no se puede deshacer.</p>

<div class="card col-md-6 mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt><dd class="col-sm-9 text-break">@Model.Nombre</dd>
            <dt class="col-sm-3">Contacto</dt><dd class="col-sm-9 text-break">@(string.IsNullOrWhiteSpace(Model.Contacto) ? "-" : Model.Contacto)</dd>
            <dt class="col-sm-3">Email</dt><dd class="col-sm-9 text-break">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>
