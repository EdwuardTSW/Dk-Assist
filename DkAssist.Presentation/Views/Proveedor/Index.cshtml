@model IEnumerable<DkAssist.Presentation.Models.ProveedorViewModel>
@{ ViewData["Title"] = "Proveedores"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Proveedores</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="CatalogoResurtido">Ver catálogo externo</a>
        <a class="btn btn-primary" asp-action="Create">Nuevo proveedor</a>
    </div>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success" role="alert" aria-live="polite">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Aún no hay proveedores registrados. Crea el primero con el botón Nuevo proveedor.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <caption class="visually-hidden">Lista de proveedores registrados</caption>
            <thead>
                <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col">Contacto</th>
                    <th scope="col">Teléfono</th>
                    <th scope="col">Email</th>
                    <th scope="col"><span class="visually-hidden">Acciones</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proveedor in Model)
                {
                    <tr>
                        <td class="text-break">@proveedor.Nombre</td>
                        <td class="text-break">@(string.IsNullOrWhiteSpace(proveedor.Contacto) ? "-" : proveedor.Contacto)</td>
                        <td>@(string.IsNullOrWhiteSpace(proveedor.Telefono) ? "-" : proveedor.Telefono)</td>
                        <td class="text-break">@(string.IsNullOrWhiteSpace(proveedor.Email) ? "-" : proveedor.Email)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@proveedor.Id" aria-label="Ver detalles de @proveedor.Nombre">Detalles</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@proveedor.Id" aria-label="Editar @proveedor.Nombre">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@proveedor.Id" aria-label="Eliminar @proveedor.Nombre">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
