@model ErrorViewModel
@{
    var esNoEncontrado = Model.StatusCode == 404;
    ViewData["Title"] = esNoEncontrado ? "Página no encontrada" : "Error";
}

@if (esNoEncontrado)
{
    <h1 class="text-danger">Página no encontrada</h1>
    <p class="lead">La página que buscas no existe o fue movida.</p>
}
else
{
    <h1 class="text-danger">Ocurrió un error</h1>
    <p class="lead">Hubo un problema al procesar tu solicitud. Intenta de nuevo en unos momentos.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            <strong>Identificador de la solicitud:</strong> <code>@Model.RequestId</code>
        </p>
    }
}

<a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
