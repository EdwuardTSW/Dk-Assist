@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool IsCurrent(string controller, string? action = null) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && (action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));

    string? NavClass(string controller, string? action = null) => IsCurrent(controller, action) ? "is-active" : null;
    string? NavCurrent(string controller, string? action = null) => IsCurrent(controller, action) ? "page" : null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DkAssist — sistema de gestión integral para tu negocio: clientes, productos, pedidos, cotizaciones, inventario, citas y pagos." />
    <title>@ViewData["Title"] - DkAssist</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="icon" type="image/png" href="~/images/brand/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DkAssist.Presentation.styles.css" asp-append-version="true" />
</head>
<body>
    <a href="#main-content" class="visually-hidden-focusable">Saltar al contenido</a>
    <div class="app-shell">
        <aside class="app-sidebar" aria-label="Navegación principal">
            <a class="app-brand" asp-area="" asp-controller="Dashboard" asp-action="Index" aria-label="DkAssist inicio">
                <span class="app-brand-mark" aria-hidden="true">
                    <img src="~/images/brand/logo.png" alt="" />
                </span>
                <span>
                    <span class="app-brand-name">DkAssist</span>
                    <span class="app-brand-subtitle">Control operativo</span>
                </span>
            </a>

            <nav class="app-nav">
                <ul>
                    <li><a class="@NavClass("Dashboard")" aria-current="@NavCurrent("Dashboard")" asp-area="" asp-controller="Dashboard" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="4" y="4" width="7" height="7" rx="2" /><rect x="13" y="4" width="7" height="4" rx="2" /><rect x="13" y="10" width="7" height="10" rx="2" /><rect x="4" y="13" width="7" height="7" rx="2" /></svg></span>Inicio</a></li>
                    <li><a class="@NavClass("Cliente")" aria-current="@NavCurrent("Cliente")" asp-area="" asp-controller="Cliente" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.5" /><path d="M5 20c.8-4 3.2-6 7-6s6.2 2 7 6" /></svg></span>Clientes</a></li>
                    <li><a class="@NavClass("Producto")" aria-current="@NavCurrent("Producto")" asp-area="" asp-controller="Producto" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" /><path d="m4.5 7.8 7.5 4.3 7.5-4.3" /><path d="M12 12v8.5" /></svg></span>Productos</a></li>
                    <li><a class="@NavClass("Proveedor")" aria-current="@NavCurrent("Proveedor")" asp-area="" asp-controller="Proveedor" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3.5 17.5h17" /><path d="M5 17.5V8l7-4 7 4v9.5" /><path d="M8 17.5v-5h8v5" /><path d="M9 9h6" /></svg></span>Proveedores</a></li>
                    <li><a class="@NavClass("Pedido")" aria-current="@NavCurrent("Pedido")" asp-area="" asp-controller="Pedido" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 4h10l2 4v12H5V8l2-4Z" /><path d="M5 8h14" /><path d="M9 12h6" /><path d="M9 16h4" /></svg></span>Pedidos</a></li>
                    <li><a class="@NavClass("Cotizacion")" aria-current="@NavCurrent("Cotizacion")" asp-area="" asp-controller="Cotizacion" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 3.5h8l3 3V20H7V3.5Z" /><path d="M15 3.5V7h3" /><path d="M9.5 11h5" /><path d="M9.5 15h5" /></svg></span>Cotizaciones</a></li>
                    <li><a class="@NavClass("MovimientoStock")" aria-current="@NavCurrent("MovimientoStock")" asp-area="" asp-controller="MovimientoStock" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 7h11" /><path d="m15 4 3 3-3 3" /><path d="M17 17H6" /><path d="m9 14-3 3 3 3" /></svg></span>Inventario</a></li>
                    <li><a class="@NavClass("Cita")" aria-current="@NavCurrent("Cita")" asp-area="" asp-controller="Cita" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="4" y="5" width="16" height="15" rx="3" /><path d="M8 3.5v3" /><path d="M16 3.5v3" /><path d="M4 10h16" /><path d="M9 15h3.5" /></svg></span>Citas</a></li>
                    <li><a class="@NavClass("Pago")" aria-current="@NavCurrent("Pago")" asp-area="" asp-controller="Pago" asp-action="Index"><span class="app-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3.5" y="6" width="17" height="12" rx="3" /><path d="M3.5 10h17" /><path d="M8 15h3" /><path d="M15.5 14.5h1" /></svg></span>Pagos</a></li>
                </ul>
            </nav>
        </aside>

        <div class="app-content">
            <main id="main-content" class="app-main">
                @RenderBody()
            </main>

            <footer class="app-footer text-muted">
                &copy; 2026 - DkAssist - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
